layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }
    tab name="homelab-monorepo" cwd="$PROJECT_SRC/homelab-monorepo"
    tab name="homelab-cli" cwd="$PROJECT_SRC/homelab-monorepo/apps/homelab-cli" split_direction="vertical" focus=true {
        pane cwd="." size="50%"
        pane cwd="." size="50%" focus=true {
            command "claude"
            args "--dangerously-skip-permissions"
        }
    }
    tab name="homelab-docs" cwd="$PROJECT_SRC/homelab-monorepo/apps/homelab-docs" split_direction="vertical" {
        pane cwd="." size="50%"
        pane cwd="." size="50%" focus=true {
            command "claude"
            args "--dangerously-skip-permissions"
        }
    }
    tab name="homelab-docs-fumadocs" cwd="$PROJECT_SRC/homelab-monorepo/apps/homelab-docs-fumadocs" split_direction="vertical" {
        pane cwd="." size="50%"
        pane cwd="." size="50%" focus=true {
            command "claude"
            args "--dangerously-skip-permissions"
        }
    }
}
